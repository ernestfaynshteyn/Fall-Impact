  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "You\u2019re awake.\n\nIt took you longer this time.\n\nI thought it might.\n\nYou
    always were the slower one.\nNot by much \u2014 just enough to notice.\n\nYour
    sibling didn\u2019t take as long.\nThey never do.\n\nThere was a lot of noise
    at first.\nQuestions, mostly.\nThe same one, repeated until it stopped meaning
    anything.\n\nIt\u2019s quieter now.\n\nYou\u2019ll notice that soon.\n\nYou always
    do."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
